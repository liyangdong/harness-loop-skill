{
  "model": "{{MODEL_ID}}",
  "max_tokens": 8192,
  "context_window": 200000,
  "tools": {
    "allow": [
      "read", "write", "edit", "bash",
      "grep", "glob"
    ]
  },
  "instruction_file": "AGENTS.md",
  "loop": {
    "max_iterations": {{MAX_ITERATIONS}},
    "stop_on_promise": true,
    "promise_token": "{{PROMISE_TOKEN}}",
    "stuck_threshold": {{STUCK_THRESHOLD}}
  }
}
