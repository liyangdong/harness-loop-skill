{
  "model": "claude-opus-4-7",
  "max_tokens": 8192,
  "context_window": 200000,
  "tools": {
    "allow": [
      "read", "write", "edit", "bash",
      "grep", "glob"
    ]
  },
  "instruction_file": "AGENTS.md",
  "loop": {
    "max_iterations": 30,
    "stop_on_promise": true,
    "promise_token": "DONE",
    "stuck_threshold": 3
  }
}
